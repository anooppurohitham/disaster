{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Disaster",
  "version": "0.0.5-alpha",
  "identifier": "com.anooppurohitham.disaster",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Disaster",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dev-placeholder",
      "endpoints": []
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "fileAssociations": [
      {
        "ext": [
          "dstr"
        ],
        "name": "Disaster Timeline Show",
        "description": "DMX Timeline show file",
        "role": "Editor",
        "mimeType": "application/x-disaster-show"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
